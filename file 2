Q3.TT_TEST IND
import numpy as np
from scipy.stats import ttest_ind

mm=float(input())
stdm=float(input())
nm=int(input())


mf=float(input())
stdf=float(input())
nf=int(input())

np.random.seed(42)
mr=np.random.normal(mm,stdm,nm)
fr=np.random.normal(mf,stdf,nf)

tst,pv=ttest_ind(mr,fr,equal_var=True)

print("Two-Sample T-Test Result (Male vs Female Fit Ratings)")
print(f"T-statistic: {tst:.4f}")
print(f"P-value: {pv:.4f}")

al=0.05
if pv < al:
    print("Reject the null hypothesis: Significant difference in fit ratings between male and female respondents.")
else:
    print("Fail to reject the null hypothesis: No significant difference in fit ratings between male and female respondents.")
        

END

Q4.CHI_2

import os
import sys
import pandas as pd
from scipy.stats import chi2_contingency


filename = input().strip()
path = os.path.join(sys.path[0], filename)


df = pd.read_csv(path)

df["Page_Loads_Bin"] = pd.qcut(
    df["Page.Loads"],
    q=3,
    labels=["Low", "Medium", "High"]
)

table = pd.crosstab(df["Day"], df["Page_Loads_Bin"])

chi2, p, dof, expected = chi2_contingency(table)

print("Null Hypothesis (H0): Page Loads are independent of Day of the Week.")
print("Alternative Hypothesis (H1): Page Loads depend on Day of the Week.\n")

print("Contingency Table (Page Loads vs Day of the Week):\n")
print(table)

print(f"\nChi-Square Statistic: {chi2:.2f}")
print(f"p-value: {p:.4f}")

if p < 0.05:
    print("\nConclusion: Reject H0. Page Loads depend on the Day of the Week.")
else:
    print("\nConclusion: Fail to Reject H0. Page Loads are independent of the Day of the Week.")

END

Q5.DATA_CLEAN

import pandas as pd
import numpy as np
import os,sys
from sklearn.preprocessing import LabelEncoder

filename = input("Enter the CSV file name (e.g., income_data.csv): ")

df = pd.read_csv(os.path.join(sys.path[0],filename))

print("Initial missing values per column:")
print(df.isnull().sum())

df.replace(' ?', np.nan, inplace=True)

print("\nMissing values per column after replacing ' ?' with NaN:")
print(df.isnull().sum())

for col in df.columns:
    if df[col].isnull().sum() > 0:
        df[col].fillna(df[col].mode()[0], inplace=True)

print("\nMissing values per column after filling with mode:")
print(df.isnull().sum())


categorical_columns = [
    "WorkClass",
    "Education",
    "Occupation",
    "Relationship",
    "Gender",
    "Native_Country",
    "Income_Bracket"
]

for col in categorical_columns:
    if col in df.columns:
        df[col] = df[col].astype("category")
    else:
        print(f"\nWarning: Column '{col}' not found in dataset.")

print("\nData types after conversion to categorical:")
print(df.dtypes)

encoder = LabelEncoder()

for col in categorical_columns:
    if col in df.columns and col != "Income_Bracket":
        df[col + "_encode"] = encoder.fit_transform(df[col])

print("\nFirst 5 rows of the processed dataframe:")
print(df.head())

END

Q6.R2_SCORE

import os
import sys
import pandas as pd
import numpy as np
import math
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import mean_squared_error,mean_absolute_error,r2_score
from sklearn.linear_model import LinearRegression
filename=input().strip()
filepath=os.path.join(sys.path[0],filename)
df=pd.read_csv(filepath)
df=df[['Customer_Age','Order_Quantity','Unit_Cost','Unit_Price','Revenue']]
df=df.fillna(df.mean(numeric_only=True))
for col in df.columns:
    q1=df[col].quantile(0.25)
    q3=df[col].quantile(0.75)
    iqr=q3-q1
    lb=q1-1.5*iqr
    ub=q3+1.5*iqr
    df[col]=df[col].clip(lower=lb,upper=ub)
s=StandardScaler()
sd=s.fit_transform(df)
sdf=pd.DataFrame(sd,columns=df.columns)
x=np.array(sdf['Unit_Cost']).reshape(-1,1)
y=sdf['Revenue']
x_train,x_test,y_train,y_test=train_test_split(x,y,test_size=0.3,random_state=200)
model=LinearRegression()
model.fit(x_train,y_train)
y=model.predict(x_test)
mse=mean_squared_error(y_test,y)
print("Mean Squared Error (MSE):",format(mse,'.4f'))
mae=mean_absolute_error(y_test,y)
print("Mean Absolute Error (MAE):",format(mae,'.4f'))
m=math.sqrt(mse)
print("Root Mean Squared Error (RMSE):",format(m,'.4f'))
r2=r2_score(y_test,y)
print("R2 Score:",format(r2,'.4f'))

END

