from itertools import combinations, combinations_with_replacement
print("Ice Cream Flavor Combination Calculator")
flavors = input("Enter ice cream flavors separated by commas (e.g., Vanilla, Chocolate, etc.): ").split(',')
flavors = [f.strip() for f in flavors if f.strip()]
n = len(flavors)
try:
    r = int(input(f"How many flavors do you want to choose (out of {n} available)?: "))
except ValueError:
    print("Invalid input")
    exit()
if not flavors or r <= 0 or r > n:
    print("Invalid input")
    exit()
without_replacement = len(list(combinations(flavors, r)))
with_replacement = len(list(combinations_with_replacement(flavors, r)))
print("\nFlavor Combinations")
print(f"Total combinations without replacement: {without_replacement}")
print(f"Total combinations with replacement: {with_replacement}")

